<Window x:Class="Bulico.DimTypeSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择尺寸标注类型"
        Height="420" Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="请选择尺寸标注类型："
                   FontSize="14" Margin="0,0,0,10"/>

        <ListBox Grid.Row="1" x:Name="DimTypeListBox" DisplayMemberPath="Name"
                 BorderBrush="#ccc" BorderThickness="1">
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="OkButton" Content="确定" Width="80" Height="28"
                    Margin="0,0,8,0" Click="OkButton_Click" IsDefault="True"/>
            <Button x:Name="CancelButton" Content="取消" Width="80" Height="28"
                    Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
